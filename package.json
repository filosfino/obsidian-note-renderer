{
  "name": "obsidian-note-renderer",
  "version": "0.5.1",
  "description": "Render markdown notes into paginated images optimized for Xiaohongshu.",
  "author": "filosfino",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/filosfino/obsidian-note-renderer.git"
  },
  "bugs": {
    "url": "https://github.com/filosfino/obsidian-note-renderer/issues"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "playground:cover": "node scripts/serve-cover-playground.mjs",
    "playground:cover:build": "node scripts/serve-cover-playground.mjs --build-only",
    "check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run check && npm run lint"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "jsdom": "^29.0.1",
    "obsidian": "^1.5.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "html-to-image": "^1.11.11",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "marked": "^17.0.4"
  }
}
